# AppClaw configuration
# Copy this file to .env and fill in your values.
# .env is gitignored. This workshop runs on LOCAL models via Ollama — no cloud
# API keys required. (Cloud providers are still supported; see the LLM section.)

# ── Confluence (for the confluence-agent script) ──────────────────────────────
# Base URL of your Atlassian instance, e.g. https://yourorg.atlassian.net
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net
# The email address you log in to Confluence with
CONFLUENCE_EMAIL=you@yourorg.com
# Atlassian API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-atlassian-api-token-here

# ── LLM (local, via Ollama) ───────────────────────────────────────────────────
# Provider: ollama (local) | anthropic | openai | gemini | groq
LLM_PROVIDER=ollama
# Ollama needs no key — the value is ignored, but some clients require a placeholder.
LLM_API_KEY=ollama
# OpenAI-compatible endpoint exposed by `ollama serve` (default port 11434).
LLM_BASE_URL=http://localhost:11434/v1
# Local model. Pull it first with:  ollama pull llama3.1
LLM_MODEL=llama3.1

# ── Vision mode ──────────────────────────────────────────────────────────────
# never    → DOM mode: reads XML page source, no image model needed (works with llama3.1)
# fallback → tries DOM first, falls back to screenshot vision
# always   → screenshot-first (requires a local vision model, see below)
VISION_MODE=never

# Local vision model for VISION_MODE=fallback or always.
# Pull with:  ollama pull llama3.2-vision   (or:  ollama pull llava)
VISION_MODEL=llama3.2-vision

# ── Device ───────────────────────────────────────────────────────────────────
PLATFORM=android
# Leave DEVICE_UDID empty to get an interactive picker, or set to ADB serial
DEVICE_UDID=emulator-5554
# DEVICE_NAME matches by partial AVD name (alternative to DEVICE_UDID)
# DEVICE_NAME=Pixel_7

# ── App ──────────────────────────────────────────────────────────────────────
# Path to the APK to install at session start (relative to the project root)
APP_PATH=apps/demo.apk

# ── Behaviour ────────────────────────────────────────────────────────────────
MAX_STEPS=30
STEP_DELAY=500
SHOW_TOKEN_USAGE=false
LLM_THINKING=off
