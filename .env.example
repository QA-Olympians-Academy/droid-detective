# AppClaw configuration
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real API keys.

# ── Anthropic (Claude Code agent + AppClaw) ──────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Confluence (for the confluence-agent script) ──────────────────────────────
# Base URL of your Atlassian instance, e.g. https://yourorg.atlassian.net
CONFLUENCE_BASE_URL=https://yourorg.atlassian.net
# The email address you log in to Confluence with
CONFLUENCE_EMAIL=you@yourorg.com
# Atlassian API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-atlassian-api-token-here

# ── LLM (AppClaw) ─────────────────────────────────────────────────────────────
# Provider: anthropic | openai | gemini | groq | ollama
LLM_PROVIDER=anthropic
LLM_API_KEY=your-anthropic-api-key-here
# Override the model (leave blank to use the provider default)
LLM_MODEL=

# ── Vision mode ──────────────────────────────────────────────────────────────
# never    → DOM mode: reads XML page source, no image model needed (works with Anthropic)
# fallback → tries DOM first, falls back to screenshot vision
# always   → screenshot-first (requires Gemini key below)
VISION_MODE=never

# Gemini key for vision mode (only needed when VISION_MODE=fallback or always)
GEMINI_API_KEY=
STARK_VISION_API_KEY=

# ── Device ───────────────────────────────────────────────────────────────────
PLATFORM=android
# Leave DEVICE_UDID empty to get an interactive picker, or set to ADB serial
DEVICE_UDID=emulator-5554
# DEVICE_NAME matches by partial AVD name (alternative to DEVICE_UDID)
# DEVICE_NAME=Pixel_7

# ── App ──────────────────────────────────────────────────────────────────────
# Path to the APK to install at session start (relative to the project root)
APP_PATH=apps/demo.apk

# ── Behaviour ────────────────────────────────────────────────────────────────
MAX_STEPS=30
STEP_DELAY=500
SHOW_TOKEN_USAGE=false
LLM_THINKING=off
